# Azure OpenAI — the Intention Engine reads these at runtime.
# Copy to .env.local and fill in. Never commit real keys.
#
# The app runs fully WITHOUT these (graceful scripted fallback), but the live,
# LLM-powered experience needs a working Azure OpenAI deployment.

# Your Azure OpenAI resource name (the part before .openai.azure.com)
AZURE_RESOURCE_NAME=

# The resource API key
AZURE_API_KEY=

# The name of the deployment you created (e.g. gpt-4o, gpt-4o-mini)
AZURE_DEPLOYMENT_NAME=

# API version for classic deployment-based URLs (e.g. 2024-10-21)
AZURE_API_VERSION=2024-10-21

# Optional: set to "true" to use the newer /openai/v1 API instead of
# classic deployment-based URLs. Leave unset for most resources.
# AZURE_USE_V1_API=false

# Optional: provide a full base URL instead of AZURE_RESOURCE_NAME
# AZURE_BASE_URL=

# Optional Azure GPT Realtime voice conversation. The server-side flag defaults
# off; the UI only offers voice when the flag and every required value are set.
# Keep the resource key server-side.
VOICE_ENABLED=false

# Deployment names created on the same Azure resource. The realtime deployment
# should target gpt-realtime-2.1 where available.
AZURE_REALTIME_DEPLOYMENT=gpt-realtime-2.1
AZURE_REALTIME_TRANSCRIPTION_DEPLOYMENT=gpt-4o-transcribe

# Optional voice and full Azure resource endpoint overrides.
AZURE_REALTIME_VOICE=marin
# AZURE_REALTIME_ENDPOINT=https://your-resource.openai.azure.com

# Realtime uses the GA /openai/v1 endpoints and intentionally has no api-version.
